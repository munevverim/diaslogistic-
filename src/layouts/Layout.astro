---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeTab?: string;
}

const { title, description = "Dias Logic - Geoteknik Mühendislik Yazılımları", activeTab = "" } = Astro.props;
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title} | Dias Logic</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- ========== TOP STRIP ========== -->
  <div class="strip"><div class="wrap">
    <span>🇹🇷 <b>%100 Türkçe</b> arayüz ve raporlama</span>
    <span>📐 <b>TBDY 2018</b> & Eurocode 7 uyumlu</span>
    <span>🎓 Akademik lisans paketi mevcut</span>
  </div></div>

  <!-- ========== HEADER ========== -->
  <header class="site"><div class="wrap"><nav class="nav">
    <a href="/" class="brand">
      <img src="/assets/logo.png" alt="Dias Logic">
      <span class="bn">Dias<span>Logic</span></span>
    </a>
    <div class="nav-links">
      <a href="/" class={activeTab === 'home' ? 'active' : ''}>Ana Sayfa</a>
      <a href="/yazilimlar" class={activeTab === 'yazilimlar' ? 'active' : ''}>Yazılımlar</a>
      <a href="/cozumler" class={activeTab === 'cozumler' ? 'active' : ''}>Çözümler</a>
      <a href="/blog" class={activeTab === 'blog' ? 'active' : ''}>Blog</a>
      <a href="/forum" class={activeTab === 'forum' ? 'active' : ''}>Forum</a>
      <a href="/hakkimizda" class={activeTab === 'hakkimizda' ? 'active' : ''}>Hakkımızda</a>
      <a href="/iletisim" class={activeTab === 'iletisim' ? 'active' : ''}>İletişim</a>
    </div>
    <div class="nav-cta">
      <a href="/iletisim" class="btn btn-ghost btn-sm">Demo Talep Et</a>
      <a href="/yazilimlar" class="btn btn-primary btn-sm">Ücretsiz Deneyin</a>
      <button class="burger" id="burger" aria-label="Menü"><span></span></button>
    </div>
  </nav></div></header>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Ana Sayfa</a>
    <a href="/yazilimlar">Yazılımlar</a>
    <a href="/cozumler">Çözümler</a>
    <a href="/blog">Blog</a>
    <a href="/forum">Forum</a>
    <a href="/hakkimizda">Hakkımızda</a>
    <a href="/iletisim">İletişim</a>
    <a href="/yazilimlar" class="btn btn-primary btn-block">Ücretsiz Deneyin</a>
  </div>

  <main id="app">
    <slot />
  </main>
  <div class="toast" id="toast"></div>

  <script>
    // Mobil menü scripti
    const burger = document.getElementById('burger');
    const mobileMenu = document.getElementById('mobileMenu');
    
    if (burger && mobileMenu) {
      burger.addEventListener('click', () => {
        mobileMenu.classList.toggle('open');
      });
      mobileMenu.addEventListener('click', (e) => {
        if (e.target instanceof HTMLAnchorElement) {
          mobileMenu.classList.remove('open');
        }
      });
    }
  </script>
</body>
</html>
